# Rockland Navigator Configuration — EXAMPLE FILE
# Copy this to config.yaml and fill in your real values.
# DO NOT commit config.yaml to git — it contains secrets.

anthropic:
  api_key: YOUR_ANTHROPIC_API_KEY

ghost:
  url: https://your-ghost-site.com
  admin_api_key: YOUR_GHOST_ADMIN_API_KEY
  # Key format is  id:secret  — find it in Ghost Admin → Settings → Integrations → Add custom integration

email:
  smtp_server: smtp.gmail.com
  smtp_port: 587
  sender: your_gmail@gmail.com
  app_password: "xxxx xxxx xxxx xxxx"
  preview_recipient: your_gmail@gmail.com

approval:
  port: 8765

logging:
  level: INFO
  file: rockland_navigator.log
